[user]
email = ms0x7f@gmail.com
name = vimday

[core]
pager = delta

[interactive]
diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections
    light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
    tabs= 4

[merge]
conflictstyle = diff3

[diff]
colorMoved = default

[credential "https://github.com"]
helper = !gh auth git-credential

[credential "https://gist.github.com"]
helper = !gh auth git-credential

[includeIf "gitdir:~/workspace/"]
path = ~/workspace/.gitconfig

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[safe]
	directory = /etc/nixos
[alias]
	dff = !git diff --name-only | fzf \\\n  --preview \"git diff --color=always {} | delta\" \\\n  --preview-window=right:70%,border-left \\\n  --bind \"ctrl-u:preview-page-up,ctrl-d:preview-page-down,shift-up:preview-up,shift-down:preview-down\" \\\n  --bind \"?:toggle-preview\"
